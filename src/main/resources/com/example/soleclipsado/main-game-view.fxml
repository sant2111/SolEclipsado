<HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.soleclipsado.controller.MainGameController">
   <children>
      <VBox alignment="CENTER" maxWidth="-Infinity" prefHeight="400.0" prefWidth="200.0" HBox.hgrow="ALWAYS">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Sol Eclipsado" />
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
            <Label text="Intentos Restantes: 6" />
         </children>
      </VBox>
      <VBox alignment="CENTER" maxWidth="-Infinity" prefHeight="400.0" prefWidth="300.0" HBox.hgrow="ALWAYS">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Ingresa una letra" />
            <TextField />
            <Label text="&quot;campo para mostrar errores de input&quot;" />
         </children>
      </VBox>
      <VBox alignment="CENTER" maxWidth="-Infinity" prefHeight="400.0" prefWidth="200.0" HBox.hgrow="ALWAYS">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Letras Usadas" />
            <GridPane>
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
